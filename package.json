{
  "name": "pi-rtk-strict",
  "version": "0.1.4-strict.1",
  "description": "RTK token reduction extension for pi-coding-agent - fork of pi-rtk with strict executable-only command matchers to prevent false positives",
  "type": "module",
  "main": "index.ts",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "bunx tsc --noEmit"
  },
  "files": [
    "*.ts",
    "techniques/*.ts",
    "README.md"
  ],
  "keywords": [
    "pi",
    "pi-coding-agent",
    "pi-package",
    "extension",
    "token-reduction",
    "rtk",
    "ai"
  ],
  "author": "Matt Cowger (original), valueforvalue (strict fork)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/valueforvalue/pi-rtk-strict.git"
  },
  "bugs": {
    "url": "https://github.com/valueforvalue/pi-rtk-strict/issues"
  },
  "homepage": "https://github.com/valueforvalue/pi-rtk-strict#readme"
}
